# 두근컴퍼니 HQ 환경 변수 — 외부 사용자용 템플릿
# 사용: cp .env.example .env  → 아래 값들 채우기
#
# ⚠️ .env 파일은 절대 커밋하지 말 것 (.gitignore 에 포함됨)

# ── 필수 ────────────────────────────────────────────────

# Anthropic Claude API 키 (Max 플랜 사용 시 — Claude Code CLI 가 host 에서 자동 인증)
# Docker 내부에서 Claude Code CLI 안 쓰면 비워둬도 됨
ANTHROPIC_API_KEY=

# Google Gemini API 키 (무료 LLM 라우터 1순위 — 토큰 절감 핵심)
# 발급: https://aistudio.google.com/app/apikey
# 무료 한도: 분당 15회, 일일 1500회
GEMINI_API_KEY=


# ── 선택 ────────────────────────────────────────────────

# Telegram Bot 토큰 (일일 리포트 알림 — 없으면 알림만 비활성)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 자동 복구 dispatch 비활성화 (실패를 사용자에게 직접 노출 — 디버깅 시)
# AUTO_RECOVERY=0

# 토큰 한도 (Claude Max 플랜 추정치)
DAILY_TOKEN_LIMIT=50000000
WINDOW_TOKEN_LIMIT=800000

# Web Push VAPID 키 (브라우저 푸시 알림용 — 없으면 푸시 비활성)
# 생성: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
