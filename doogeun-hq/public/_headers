# CF Pages cache policy

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/_next/static/media/*
  Cache-Control: public, max-age=31536000, immutable

/assets/chars/*
  Cache-Control: public, max-age=2592000

/assets/npcs/*
  Cache-Control: public, max-age=2592000

/assets/teammaker/*
  Cache-Control: public, max-age=2592000

/assets/buildings/*
  Cache-Control: public, max-age=2592000

/assets/floors/*
  Cache-Control: public, max-age=2592000

/version.json
  Cache-Control: no-store

/embed/*
  Cache-Control: public, max-age=0, must-revalidate

# HTML 라우트는 항상 새로 받아오게 — 배포 후 캐시 잔존으로 매번 캐시삭제 강요받는 문제 회피.
# 위의 immutable /_next/static/* 가 더 구체적이라 정적 hash 파일은 그대로 1년 캐시.
